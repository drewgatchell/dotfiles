# ~/.gitconfig - Portable git configuration
# Managed by dotfiles: https://github.com/drew/dotfiles

[core]
    editor = nvim
    excludesFile = ~/.gitignore_global
    autocrlf = input
    pager = less -FRX

[init]
    defaultBranch = main

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true

[fetch]
    prune = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[rebase]
    autoStash = true

[alias]
    # Status and log
    s = status -sb
    l = log --oneline -20
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

    # Branching
    co = checkout
    cob = checkout -b
    br = branch
    brd = branch -d

    # Commits
    c = commit
    cm = commit -m
    ca = commit --amend
    can = commit --amend --no-edit

    # Working with changes
    aa = add --all
    ap = add --patch
    d = diff
    ds = diff --staged

    # Undo
    undo = reset HEAD~1 --mixed
    unstage = reset HEAD --

    # Stash
    st = stash
    stp = stash pop
    stl = stash list

    # Remote
    p = push
    pushf = push --force-with-lease
    pl = pull

    # Maintenance
    cleanup = "!git branch --merged | grep -v '\\*\\|main\\|master\\|develop\\|staging\\|release' | xargs -n 1 git branch -d"

[color]
    ui = auto

[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green

[color "diff"]
    meta = yellow bold
    frag = magenta bold
    old = red bold
    new = green bold

[color "status"]
    added = green
    changed = yellow
    untracked = red

# Include local config for user-specific settings
# This allows machine-specific email, signing keys, etc.
[include]
    path = ~/.gitconfig.local
