{
  // Zed Settings
  // https://zed.dev/docs/configuring-zed
  // Managed by dotfiles

  // ==========================================================================
  // Theme
  // ==========================================================================

  "theme": "Dracula",

  // ==========================================================================
  // Font
  // ==========================================================================

  "buffer_font_family": "JetBrains Mono",
  "buffer_font_size": 14,
  "ui_font_size": 15,

  // ==========================================================================
  // Editor
  // ==========================================================================

  "tab_size": 4,
  "soft_wrap": "none",
  "show_whitespaces": "selection",
  "relative_line_numbers": true,
  "cursor_blink": false,
  "vertical_scroll_margin": 8,

  // Inlay hints
  "inlay_hints": {
    "enabled": true,
    "show_type_hints": true,
    "show_parameter_hints": true
  },

  // ==========================================================================
  // Git
  // ==========================================================================

  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 500
    }
  },

  // ==========================================================================
  // Terminal
  // ==========================================================================

  "terminal": {
    "font_family": "JetBrains Mono",
    "font_size": 14,
    "line_height": "comfortable",
    "shell": {
      "program": "zsh"
    }
  },

  // ==========================================================================
  // File handling
  // ==========================================================================

  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "autosave": "on_focus_change",

  // ==========================================================================
  // UI
  // ==========================================================================

  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": true
  },

  "scrollbar": {
    "show": "auto"
  },

  "indent_guides": {
    "enabled": true,
    "coloring": "fixed"
  },

  // ==========================================================================
  // Vim mode (optional - uncomment to enable)
  // ==========================================================================

  // "vim_mode": true,
  // "vim": {
  //   "use_system_clipboard": "always"
  // },

  // ==========================================================================
  // Language-specific settings
  // ==========================================================================

  "languages": {
    "Python": {
      "tab_size": 4
    },
    "JavaScript": {
      "tab_size": 2
    },
    "TypeScript": {
      "tab_size": 2
    },
    "JSON": {
      "tab_size": 2
    },
    "YAML": {
      "tab_size": 2
    },
    "Markdown": {
      "soft_wrap": "editor_width"
    }
  }
}
